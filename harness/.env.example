# Carbono harness — copy to .env and fill in. NEVER commit .env.
# OpenRouter-first strategy: this one key covers every model with an openrouter_id.
OPENROUTER_API_KEY=

# Required for chat-latest (no OpenRouter route) and for pinning the
# gpt-5.5-2026-04-23 snapshot natively:
OPENAI_API_KEY=

# Optional native fallbacks (only needed if OpenRouter is down/missing a model):
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
